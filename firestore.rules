rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ──────────────────────────────────────────────
    // Mọi user đã auth đều có thể đọc profile user khác
    // Chỉ owner mới có thể ghi (cập nhật gamification, profile)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      // Badges subcollection — chỉ owner
      match /badges/{badgeId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }
    }

    // ── History (sessions) ────────────────────────────────
    // Chỉ owner mới có thể đọc/ghi lịch sử chơi
    match /history/{userId}/sessions/{sessionId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
      // Không cho phép update/delete session đã tạo
    }

    // ── Periods (read-only cho auth users) ────────────────
    match /periods/{document=**} {
      allow read: if request.auth != null;
    }

    // ── Periods Person (read-only) ────────────────────────
    match /periods_person/{document=**} {
      allow read: if request.auth != null;
    }

    // ── Games (read-only) ─────────────────────────────────
    match /games/{document=**} {
      allow read: if request.auth != null;
    }

    // ── Explore (read-only) ───────────────────────────────
    match /explore/{document=**} {
      allow read: if request.auth != null;
    }

    // ── Forum ─────────────────────────────────────────────
    match /forum/{postId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /replies/{replyId} {
        allow read, write: if request.auth != null;
      }

      // User chỉ được tạo báo cáo của chính mình. Mọi thao tác moderation
      // được thực hiện bằng Firebase Admin SDK trên web quản trị.
      match /reports/{reportId} {
        allow create: if request.auth != null
          && request.resource.data.reporterId == request.auth.uid
          && request.resource.data.status == 'pending';
        allow read, update, delete: if false;
      }
    }
  }
}
